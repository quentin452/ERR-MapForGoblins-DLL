[paths]
# Path to ERR mod directory (contains regulation.bin, map/, event/, msg/ etc.)
# Example: C:\Games\ERR\ERRv2.2.1.2\mod
err_mod_dir =

# Path to Elden Ring game directory (contains eldenring.exe, oo2core_6_win64.dll)
# Example: C:\Steam\steamapps\common\ELDEN RING\Game
game_dir =

# Optional: path to The Convergence's ModEngine2 'mod' overlay directory
# (contains regulation.bin, map/, event/, msg/ etc.). Only needed for the
# convergence build profile (build.bat ... --convergence). game_dir must also
# be set and UXM-unpacked: the overlay is partial, so the pipeline stages a
# merged overlay-over-vanilla view first (tools/prepare_merged_src.py).
# Example: C:\Games\ConvergenceER\mod
convergence_mod_dir =

# Optional: path to the ERTE overhaul's mod overlay dir, for the erte build
# profile (build.bat ... --erte). game_dir must also be set and UXM-unpacked
# (partial overlay -> staged merged-over-vanilla view, same as convergence).
# Example: C:\...\me3\config\profiles\eldenring-mods\ERTE SOTE
erte_mod_dir =

# Optional: path to SmithBox install (only needed by some research scripts
# under tools/_*.py — not required by the core build pipeline).
# Example: C:\Tools\Smithbox_2_1_2_2016_02_16_a
smithbox_dir =

# Optional: path to <DarkScript3>/Resources/ — used by tools/emevd_decompile.py
# for human-readable entity/model/event names. Without it the EMEDF JSON in
# tools/er-common.emedf.json is still used (instruction decoding works), but
# names appear as raw IDs.
# Example: C:\Tools\Darkscript3_6_3\Resources
darkscript_resources =
