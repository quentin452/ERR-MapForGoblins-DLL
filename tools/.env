# MapForGoblins build/tooling paths — committed TEMPLATE (placeholders only).
#
# Put your REAL per-machine paths in .env.local (gitignored). Precedence:
#     real shell env  >  .env.local  >  .env   (and tools/ overrides repo root)
# Any var left blank here falls back to tools/config.ini, then to each tool's
# built-in default, so the build keeps working with no env files at all.
# Loaded by tools/load_env.py (invoked from tools/config.py at import time).
# This file may live here (tools/) or in the repo root; both are searched.

# ERR mod directory — contains regulation.bin, map/, event/, msg/ ...
# e.g. C:\Games\ERR\ERRv2.2.1.2\mod   or   /home/you/Games/ERR/mod
ERR_MOD_DIR=

# Elden Ring game directory — eldenring.exe, oo2core_6_win64.dll.
# Must be UXM-unpacked (loose regulation.bin/map/event/msg) for the vanilla profile.
# e.g. C:\Steam\steamapps\common\ELDEN RING\Game
GAME_DIR=

# The Convergence's ModEngine2 'mod' overlay dir (only for --convergence builds).
# e.g. C:\Games\ConvergenceER\mod
CONVERGENCE_MOD_DIR=

# ERTE overhaul's mod overlay dir (only for --erte builds).
# e.g. C:\...\me3\config\profiles\eldenring-mods\ERTE SOTE
ERTE_MOD_DIR=

# SmithBox install (only needed by some research scripts under tools/_*.py).
# e.g. C:\Tools\Smithbox_2_1_2_2016_02_16_a
SMITHBOX_DIR=

# <DarkScript3>/Resources/ — optional, for tools/emevd_decompile.py name resolution.
# e.g. C:\Tools\Darkscript3_6_3\Resources
DARKSCRIPT_RESOURCES=

# FFDEC / JPEXS Free Flash Decompiler CLI command for tools/build_vanilla_gfx.py.
# Whole command line, whitespace-split — so prefer the `java -jar ...` form or a
# space-free path. If unset, the scripts (build_vanilla_gfx.py, render_map_icons.py)
# auto-detect a known local install.
# e.g. java -jar /home/you/FFDec/ffdec-cli.jar
# or:  C:\Program Files (x86)\FFDec\ffdec-cli.exe
FFDEC_CLI=

# Optional (research only): override the dirs tools/analyze_massedit_comparison.py
# compares. Default to <repo>/data[/<profile>]/massedit and .../massedit_generated.
MFG_MASSEDIT_ORIG_DIR=
MFG_MASSEDIT_GEN_DIR=
